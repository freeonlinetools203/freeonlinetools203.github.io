<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>PDF to PNG - Convert PDF to PNG | Free Online Tools</title>
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:linear-gradient(135deg,#1E3A8A 0%,#0D9488 100%);min-height:100vh;padding:20px;}
        .container{max-width:550px;margin:0 auto;}
        .card{background:white;border-radius:32px;padding:30px;box-shadow:0 25px 50px rgba(0,0,0,0.25);text-align:center;}
        body.dark-mode .card{background:#1e293b;}
        h1{color:#1E3A8A;font-size:28px;margin-bottom:10px;}
        body.dark-mode h1{color:#0D9488;}
        .sub{color:#0D9488;font-size:14px;margin-bottom:30px;}
        .upload-area{border:2px dashed #0D9488;border-radius:24px;padding:50px 20px;text-align:center;cursor:pointer;background:#f8fafc;margin-bottom:20px;}
        body.dark-mode .upload-area{background:#334155;}
        .upload-icon{font-size:48px;margin-bottom:10px;}
        .action-btn{width:100%;background:linear-gradient(135deg,#1E3A8A 0%,#0D9488 100%);color:white;border:none;padding:16px;border-radius:50px;font-size:18px;font-weight:bold;cursor:pointer;}
        .info-text{text-align:center;color:#0D9488;font-size:12px;background:#f0fdf4;padding:12px;border-radius:16px;margin-top:20px;}
        .dark-toggle{background:#f1f5f9;border:none;padding:8px 16px;border-radius:50px;cursor:pointer;float:right;}
    </style>
</head>
<body>
<div class="container">
    <div class="card">
        <button class="dark-toggle" onclick="toggleDarkMode()">🌙 Dark Mode</button>
        <h1>📸 PDF to PNG</h1>
        <p class="sub">Convert PDF pages to PNG images</p>
        <div class="upload-area" onclick="document.getElementById('fileInput').click()">
            <div class="upload-icon">📑</div>
            <div>Click to upload PDF</div>
            <div style="font-size:12px;color:#64748b;">PDF only (Max 10MB)</div>
            <input type="file" id="fileInput" accept="application/pdf" style="display:none">
        </div>
        <button class="action-btn" onclick="convert()">🔄 Convert to PNG</button>
        <div class="info-text">💡 Convert PDF pages to PNG with transparent background support.</div>
    </div>
</div>
<script>
    function convert(){alert('PDF to PNG conversion coming soon!');}
    function toggleDarkMode(){document.body.classList.toggle('dark-mode');}
</script>
</body>
</html>
